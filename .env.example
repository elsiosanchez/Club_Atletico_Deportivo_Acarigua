# Aplicación
APP_NAME="Club Atlético Deportivo Acarigua"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Caracas

# Base de datos (MySQL / MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cada_db
DB_USER=root
DB_PASS=

# Autenticación JWT
# Genera uno nuevo con: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_TTL=7200
JWT_REFRESH_TTL=604800

# Subida de archivos
UPLOAD_MAX_SIZE=2097152
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp
